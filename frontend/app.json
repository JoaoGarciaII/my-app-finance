{
  "expo": {
    "name": "My Finance",
    "slug": "my-finance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.joaogarcia.myfinance"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "scheme": "myfinance",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4722abe7-a2c1-46c8-bf13-902fe3153330"
      }
    }
  }
}